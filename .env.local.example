# Supabase - copie este arquivo para `.env.local` e preencha os valores
# disponíveis em https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Gemini - leitura automática da ficha de empregado (PDF/imagem)
# Chave em https://aistudio.google.com/apikey  ·  modelos: ListModels da sua chave
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
